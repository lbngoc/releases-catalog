<header class="site-header border-b border-slate-200 bg-slate-50">
  <div class="w-full max-w-5xl mx-auto px-4 py-6 flex flex-col gap-4">
    <!-- Row 1 -->
    <div class="flex items-start gap-3">
      <div class="size-12 md:size-16 flex items-center justify-center">
        <img src="favicon.svg" alt="Logo" class="size-12 md:size-16"/>
      </div>
      <div>
        <h1 class="text-2xl/tight md:text-3xl/tight font-extrabold tracking-tight text-slate-900">
          Releases Catalog
        </h1>
        <p class="text-xs md:text-sm text-slate-500">
          Browse versioned builds and release notes
        </p>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="flex flex-wrap items-center gap-2 md:gap-4 text-slate-500 text-xs md:text-sm">
      <!-- Latest Version Badge -->
      <span
        class="inline-flex items-center gap-2 rounded-full border border-green-600 text-green-600 px-3 py-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4">
          <path d="M2.75 2a.75.75 0 0 0-.75.75v10.5a.75.75 0 0 0 1.5 0v-2.624l.33-.083A6.044 6.044 0 0 1 8 11c1.29.645 2.77.807 4.17.457l1.48-.37a.462.462 0 0 0 .35-.448V3.56a.438.438 0 0 0-.544-.425l-1.287.322C10.77 3.808 9.291 3.646 8 3a6.045 6.045 0 0 0-4.17-.457l-.34.085A.75.75 0 0 0 2.75 2Z"/>
        </svg>
        <span class="font-semibold">
          <span x-text="latestVersion ? `v${latestVersion}` : '--'"></span>
        </span>
      </span>
      <!-- Sync / Refresh -->
      <button
        class="inline-flex items-center gap-2 rounded-full border border-slate-300 text-slate-600 hover:border-slate-800 hover:text-slate-800 px-3 py-1 transition"
        @click="refreshAll()">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" :class="loading ? 'animate-spin' : ''">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z"/>
        </svg>
        <span>
          Updated:
          <span x-text="latestUpdate ? latestUpdate : '--'"></span>
        </span>
      </button>
    </div>
  </div>
</header>