<section x-init="init()">
  <div class="space-y-6" role="list">

    <!-- Global Skeleton -->
    <template x-if="loading">
      <div class="space-y-6">
        <template x-for="i in pageSize" :key="i">
          <div class="grid md:grid-cols-[200px_1fr] gap-2 md:gap-4 animate-pulse">
            <div class="space-y-3 py-4">
              <div class="h-4 w-24 bg-slate-200 rounded"></div>
              <div class="h-4 w-16 bg-slate-200 rounded"></div>
            </div>
            <div class="p-4 border border-slate-200 rounded-lg space-y-4">
              <div class="h-6 w-1/2 bg-slate-200 rounded"></div>
              <div class="h-4 w-1/3 bg-slate-200 rounded"></div>
              <div class="space-y-2">
                <div class="h-3 w-full bg-slate-200 rounded"></div>
                <div class="h-3 w-5/6 bg-slate-200 rounded"></div>
                <div class="h-3 w-4/6 bg-slate-200 rounded"></div>
              </div>
            </div>
          </div>
        </template>
      </div>
    </template>

    <!-- Error  -->
    <template x-if="!loading && totalItems < 0">
      <div
        class="rounded-md border px-4 py-3 text-sm border-red-200 bg-red-50 text-red-700">
          Failed to load release list.
      </div>
    </template>

  <!-- Empty  -->
    <template x-if="!loading && totalItems === 0">
      <div
        class="rounded-md border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-700">
          Release list will appear once <strong>catalog.csv</strong> is populated.
      </div>
    </template>

    <!-- Releases -->
    <template
      x-for="(release, idx) in paginated"
      :key="(currentPage - 1) * pageSize + idx">

      <div class="grid md:grid-cols-[200px_1fr] gap-2 md:gap-4 transition">
        <!-- LEFT META -->
        <div class="text-sm text-slate-500 md:space-y-2 py-6 border-t border-slate-200 md:border-t-0">
          <div
            class="text-base font-semibold text-slate-800"
            x-text="release.date"></div>
          <div class="text-sm font-medium mb-2 md:mb-4">
            v<span x-text="release.versionCode"></span>
          </div>

          <!-- Sprint -->
          <template x-if="changelogs[release.versionCode]?.data?.frontmatter?.sprint">
            <div class="flex items-center gap-2">
              <svg aria-label="Tag" role="img" class="size-4" viewBox="0 0 16 16">
                <path d="M1 7.775V2.75C1 1.784 1.784 1 2.75 1h5.025c.464 0 .91.184 1.238.513l6.25 6.25a1.75 1.75 0 0 1 0 2.474l-5.026 5.026a1.75 1.75 0 0 1-2.474 0l-6.25-6.25A1.752 1.752 0 0 1 1 7.775Zm1.5 0c0 .066.026.13.073.177l6.25 6.25a.25.25 0 0 0 .354 0l5.025-5.025a.25.25 0 0 0 0-.354l-6.25-6.25a.25.25 0 0 0-.177-.073H2.75a.25.25 0 0 0-.25.25ZM6 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z"></path>
              </svg>
              <span>
                Sprint
                <span x-text="changelogs[release.versionCode].data.frontmatter.sprint"></span>
              </span>
            </div>
          </template>

          <!-- Hash -->
          <template x-if="changelogs[release.versionCode]?.data?.frontmatter?.hash">
            <div class="flex items-center gap-2">
              <svg aria-label="Commit" role="img" class="size-4" viewBox="0 0 16 16">
                <path d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"></path>
              </svg>
              <span class="overflow-hidden text-ellipsis max-w-[80vw] md:max-w-[75%]" x-text="changelogs[release.versionCode].data.frontmatter.hash"></span>
            </div>
          </template>
        </div>

        <!-- RIGHT CONTENT -->
        <div class="p-4 border rounded-lg text-sm text-slate-700"
        :class="activeHashVersion === release.versionCode && changelogs[release.versionCode]?.data
          ? 'md:ring-2 md:ring-blue-500 md:ring-offset-2 border-blue-200'
          : 'border-slate-300'"
        >

          <!-- Changelog Skeleton -->
          <template x-if="changelogs[release.versionCode]?.status === 'loading'">
            <div class="space-y-4 animate-pulse">
              <div class="h-6 w-1/2 bg-slate-200 rounded"></div>
              <div class="h-4 w-1/3 bg-slate-200 rounded"></div>
              <div class="space-y-2">
                <div class="h-3 w-full bg-slate-200 rounded"></div>
                <div class="h-3 w-5/6 bg-slate-200 rounded"></div>
                <div class="h-3 w-4/6 bg-slate-200 rounded"></div>
              </div>
            </div>
          </template>

          <!-- Error -->
          <template x-if="changelogs[release.versionCode]?.status === 'error'">
            <p class="text-red-200 italic">
              Unable to load release notes.
            </p>
          </template>

          <!-- Loaded -->
          <template x-if="changelogs[release.versionCode]?.status === 'loaded'">
            <div :id="'v' + release.versionCode" class="space-y-4">
              <!-- Title + Share -->
              <div class="flex justify-between items-start gap-4">
                <h3 class="text-xl/tight md:text-2xl/tight font-semibold text-slate-900"
                    x-text="changelogs[release.versionCode].data?.frontmatter?.title"></h3>

                <div class="flex items-center gap-2">
                  <!-- Refresh button -->
                  <button
                    class="border border-slate-200 rounded-lg p-2 bg-slate-100 hover:bg-slate-200 transition"
                    @click="refreshVersion(release.versionCode)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                      <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/>
                    </svg>
                  </button>

                  <!-- Share button -->
                  <button
                    class="border border-slate-200 rounded-lg p-2 bg-slate-100 hover:bg-slate-200 transition flex items-center justify-center"
                    @click="copySharedUrl(release.versionCode)">
                    <template x-if="copiedVersion === release.versionCode">
                      <span class="text-green-600 text-xs font-semibold">
                        Copied!
                      </span>
                    </template>
                    <template x-if="copiedVersion !== release.versionCode">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                        <path fill-rule="evenodd" d="M19.902 4.098a3.75 3.75 0 0 0-5.304 0l-4.5 4.5a3.75 3.75 0 0 0 1.035 6.037.75.75 0 0 1-.646 1.353 5.25 5.25 0 0 1-1.449-8.45l4.5-4.5a5.25 5.25 0 1 1 7.424 7.424l-1.757 1.757a.75.75 0 1 1-1.06-1.06l1.757-1.757a3.75 3.75 0 0 0 0-5.304Zm-7.389 4.267a.75.75 0 0 1 1-.353 5.25 5.25 0 0 1 1.449 8.45l-4.5 4.5a5.25 5.25 0 1 1-7.424-7.424l1.757-1.757a.75.75 0 1 1 1.06 1.06l-1.757 1.757a3.75 3.75 0 1 0 5.304 5.304l4.5-4.5a3.75 3.75 0 0 0-1.035-6.037.75.75 0 0 1-.354-1Z" clip-rule="evenodd"/>
                      </svg>
                    </template>
                  </button>
                </div>
              </div>

              <!-- Meta -->
              <div class="flex flex-wrap gap-2 text-xs text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                  <path fill-rule="evenodd" d="M12 3.75a6.715 6.715 0 0 0-3.722 1.118.75.75 0 1 1-.828-1.25 8.25 8.25 0 0 1 12.8 6.883c0 3.014-.574 5.897-1.62 8.543a.75.75 0 0 1-1.395-.551A21.69 21.69 0 0 0 18.75 10.5 6.75 6.75 0 0 0 12 3.75ZM6.157 5.739a.75.75 0 0 1 .21 1.04A6.715 6.715 0 0 0 5.25 10.5c0 1.613-.463 3.12-1.265 4.393a.75.75 0 0 1-1.27-.8A6.715 6.715 0 0 0 3.75 10.5c0-1.68.503-3.246 1.367-4.55a.75.75 0 0 1 1.04-.211ZM12 7.5a3 3 0 0 0-3 3c0 3.1-1.176 5.927-3.105 8.056a.75.75 0 1 1-1.112-1.008A10.459 10.459 0 0 0 7.5 10.5a4.5 4.5 0 1 1 9 0c0 .547-.022 1.09-.067 1.626a.75.75 0 0 1-1.495-.123c.041-.495.062-.996.062-1.503a3 3 0 0 0-3-3Zm0 2.25a.75.75 0 0 1 .75.75c0 3.908-1.424 7.485-3.781 10.238a.75.75 0 0 1-1.14-.975A14.19 14.19 0 0 0 11.25 10.5a.75.75 0 0 1 .75-.75Zm3.239 5.183a.75.75 0 0 1 .515.927 19.417 19.417 0 0 1-2.585 5.544.75.75 0 0 1-1.243-.84 17.915 17.915 0 0 0 2.386-5.116.75.75 0 0 1 .927-.515Z" clip-rule="evenodd"/>
                </svg>
                <span x-text="changelogs[release.versionCode].data?.frontmatter?.code"></span>
                <span></span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                  <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z" clip-rule="evenodd"/>
                </svg>
                <span x-text="formatTime(changelogs[release.versionCode].data?.frontmatter?.date)"></span>
              </div>

              <!-- Description -->
              <template x-if="changelogs[release.versionCode]?.data?.frontmatter?.description">
                <div class="flex flex-wrap gap-2 text-base text-slate-900">
                  <div x-text="changelogs[release.versionCode]?.data?.frontmatter?.description"></div>
                </div>
              </template>

              <!-- Assets -->
              <template x-if="changelogs[release.versionCode]?.data?.frontmatter?.assets?.length">
                <ul class="border rounded-lg bg-slate-100 border-slate-200">
                  <template
                    x-for="asset in changelogs[release.versionCode].data.frontmatter.assets"
                    :key="asset">
                    <li class="flex items-center gap-2 border-b border-slate-200 last:border-b-0 px-4 py-2">
                      <img :src="getAssetIconUrl(asset)" class="size-4"/>
                      <a
                        class="text-blue-500 font-medium hover:underline"
                        :href="getAssetDownloadUrl(release.version, asset)"
                        download
                        x-text="getAssetDownloadName(release.version, asset)"></a>
                    </li>
                  </template>
                </ul>
              </template>

              <!-- Markdown -->
              <details
                :open="activeHashVersion === release.versionCode"
                @toggle="onDetailsToggle($event, release.versionCode)"
                class="group">
                <summary class="cursor-pointer flex items-center justify-between py-2">
                  <span class="text-xl font-semibold">
                    What's Changed
                  </span>
                  <!-- Optional: chevron rotate animation -->
                  <svg
                    class="size-6 transition-transform group-open:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </summary>
                <div
                  class="markdown border-t border-slate-200 pt-4"
                  x-html="changelogs[release.versionCode]?.data?.html"></div>
              </details>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div>

  <!-- Pagination -->
  <template x-if="totalPages > 1">
    <div class="flex flex-wrap gap-2 mt-8">
      <button
        class="px-3 py-1 border rounded-md disabled:opacity-30 disabled:pointer-events-none"
        :disabled="currentPage === 1"
        @click="changePage(currentPage - 1)">
        Previous
      </button>

      <template x-for="page in totalPages" :key="page">
        <button
          class="px-3 py-1 border rounded-md"
          :class="page === currentPage
            ? 'bg-slate-900 text-white border-slate-900'
            : 'border-slate-200 hover:border-slate-300'"
          @click="changePage(page)"
          x-text="page"></button>
      </template>

      <button
        class="px-3 py-1 border rounded-md disabled:opacity-30 disabled:pointer-events-none"
        :disabled="currentPage === totalPages"
        @click="changePage(currentPage + 1)">
        Next
      </button>
    </div>
  </template>

</section>